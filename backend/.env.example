# Copy this file to backend/.env and fill in real values.
# Never commit backend/.env — it is gitignored.

# --- Anthropic ---
# Used for Claude Haiku tool-use across resume parsing, signal extraction,
# job extraction, and fit scoring.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# SUPABASE_URL    : your project URL, e.g. https://<ref>.supabase.co
# SUPABASE_KEY    : the anon (publishable) key — used by the FastAPI app
#                   for OAuth redirects and PostgREST reads via the
#                   authenticated user's JWT.
# SUPABASE_SECRET_KEY : the service-role key — required only for server-
#                       side admin reads/writes that bypass RLS.
# SUPABASE_REDIRECT_URI : OAuth callback URL registered in Supabase.
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_KEY=eyJhbGciOi...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
